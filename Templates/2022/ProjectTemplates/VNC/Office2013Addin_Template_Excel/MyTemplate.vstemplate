<VSTemplate Version="3.0.0" xmlns="http://schemas.microsoft.com/developer/vstemplate/2005" Type="Project">
  <TemplateData>
    <Name>Office2013Addin_Template_Excel</Name>
    <Description>Office 2013 Addin Template Starter Kit for Excel</Description>
    <ProjectType>CSharp</ProjectType>
    <ProjectSubType>
    </ProjectSubType>
    <SortOrder>1000</SortOrder>
    <CreateNewFolder>true</CreateNewFolder>
    <DefaultName>Office2013Addin_Template_Excel</DefaultName>
    <ProvideDefaultName>true</ProvideDefaultName>
    <LocationField>Enabled</LocationField>
    <EnableLocationBrowseButton>true</EnableLocationBrowseButton>
    <Icon>__TemplateIcon.ico</Icon>
  </TemplateData>
  <TemplateContent>
    <Project File="SupportTools_Excel.csproj" ReplaceParameters="true">
      <Folder Name="Actions">
        <ProjectItem ReplaceParameters="true">Excel_FolderMaps.cs</ProjectItem>
        <ProjectItem ReplaceParameters="true">Excel_PageFormatting.cs</ProjectItem>
        <ProjectItem ReplaceParameters="true">Excel_TableOfContents.cs</ProjectItem>
      </Folder>
      <ProjectItem ReplaceParameters="true">App.config</ProjectItem>
      <ProjectItem ReplaceParameters="true">Common.cs</ProjectItem>
      <Folder Name="Data">
        <ProjectItem ReplaceParameters="true">ApplicationDS.xsd</ProjectItem>
        <ProjectItem ReplaceParameters="true">ApplicationDS.cs</ProjectItem>
        <ProjectItem ReplaceParameters="true">ApplicationDS.Designer.cs</ProjectItem>
        <ProjectItem ReplaceParameters="false">ApplicationDS.xsc</ProjectItem>
        <ProjectItem ReplaceParameters="false">ApplicationDS.xss</ProjectItem>
        <ProjectItem ReplaceParameters="true">Config.cs</ProjectItem>
        <ProjectItem ReplaceParameters="true">DbInstanceList.xml</ProjectItem>
        <ProjectItem ReplaceParameters="true">ExcelMtreatyConfig.xml</ProjectItem>
        <ProjectItem ReplaceParameters="true">MTreatyFileTypeList.xml</ProjectItem>
        <ProjectItem ReplaceParameters="true">SPSiteProvision.xml</ProjectItem>
        <ProjectItem ReplaceParameters="true">SupportTools_Config.xml</ProjectItem>
      </Folder>
