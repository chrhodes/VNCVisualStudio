        <ProjectItem ReplaceParameters="true">AssemblyInfo.cs</ProjectItem>
        <ProjectItem ReplaceParameters="false">licenses.licx</ProjectItem>
        <ProjectItem ReplaceParameters="true">Resources.resx</ProjectItem>
        <ProjectItem ReplaceParameters="true">Resources.Designer.cs</ProjectItem>
        <ProjectItem ReplaceParameters="true">Settings.settings</ProjectItem>
        <ProjectItem ReplaceParameters="true">Settings.Designer.cs</ProjectItem>
      </Folder>
      <Folder Name="Resources">
        <ProjectItem ReplaceParameters="false">add footer.bmp</ProjectItem>
        <ProjectItem ReplaceParameters="false">add header.bmp</ProjectItem>
        <ProjectItem ReplaceParameters="false">vstg0001.bmp</ProjectItem>
        <ProjectItem ReplaceParameters="false">Auto-Debug-System_icon.gif</ProjectItem>
        <ProjectItem ReplaceParameters="false">Chart.bmp</ProjectItem>
        <ProjectItem ReplaceParameters="false">folder map.bmp</ProjectItem>
        <ProjectItem ReplaceParameters="false">format landscape.bmp</ProjectItem>
        <ProjectItem ReplaceParameters="false">format portrait.bmp</ProjectItem>
        <ProjectItem ReplaceParameters="false">group down all.bmp</ProjectItem>
